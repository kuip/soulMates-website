---
import { getCollection, render } from 'astro:content';
import MarkdownLayout from '../../layouts/MarkdownLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { id: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<MarkdownLayout title={`${post.data.title} — soulMates`} description={post.data.description}>
  <script
    type="application/ld+json"
    set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'BlogPosting',
      headline: post.data.title,
      description: post.data.description,
      datePublished: post.data.date.toISOString(),
      url: `https://soulmates.provable.dev/blog/${post.id}`,
      keywords: post.data.tags,
      author: {
        '@type': 'Organization',
        name: 'Kuip Limited',
        url: 'https://soulmates.provable.dev',
      },
      publisher: {
        '@type': 'Organization',
        name: 'Kuip Limited',
        logo: {
          '@type': 'ImageObject',
          url: 'https://soulmates.provable.dev/icons/icon-512.png',
        },
      },
    })}
  />
  <p class="meta">
    <time datetime={post.data.date.toISOString()}>
      {post.data.date.toLocaleDateString('en-US', {
        year: 'numeric',
        month: 'long',
        day: 'numeric',
      })}
    </time>
  </p>
  <Content />
</MarkdownLayout>

<style>
  .meta {
    color: var(--muted);
    font-size: 0.9rem;
    margin-bottom: 24px;
  }
</style>
