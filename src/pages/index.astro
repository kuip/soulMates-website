---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="soulMates — Discover together your music DNA">
  <section class="hero">
    <img src="/icons/hero-logo.png" alt="soulMates" class="hero-logo" />
    <h1>Discover together your<br /><span class="accent">music DNA</span></h1>
    <p class="subtitle">
      Swipe through tracks, reveal your musical personality, listen with your friends in sync and react to songs.
      Find people who truly share your taste.
    </p>
    <div class="cta-row">
      <a href="#" class="btn btn-primary">App Store</a>
      <a href="#" class="btn btn-outline">Google Play</a>
    </div>
  </section>

  <section class="features">
    <div class="feature">
      <div class="feature-icon"><svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="#e7b10a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3" fill="#e7b10a" stroke="#e7b10a"/><circle cx="18" cy="16" r="3" fill="#e7b10a" stroke="#e7b10a"/></svg></div>
      <h3>Swipe & Discover</h3>
      <p>
        Listen to curated tracks and swipe to build your musical profile. Every
        choice shapes your unique music genome.
      </p>
    </div>
    <div class="feature">
      <div class="feature-icon">🧬</div>
      <h3>Music Genome</h3>
      <p>
        12 musical axes map your taste across energy, valence, complexity, and
        more. See your personality through music.
      </p>
    </div>
    <div class="feature">
      <div class="feature-icon">💜</div>
      <h3>Find Your Soulmates</h3>
      <p>
        Match with people whose musical aura aligns with yours. Chat, share
        tracks, and discover music together.
      </p>
    </div>
  </section>

  <section class="screenshots" id="screenshots">
    <h2>See it in action</h2>
    <div class="carousel">
      <button class="carousel-btn carousel-prev" aria-label="Previous" id="carouselPrev">&lsaquo;</button>
      <div class="carousel-track" id="carouselTrack">
        <img src="/screenshots/IMG_2948.PNG" alt="soulMates screenshot" loading="lazy" />
        <img src="/screenshots/IMG_2949.PNG" alt="soulMates screenshot" loading="lazy" />
        <img src="/screenshots/IMG_2951.PNG" alt="soulMates screenshot" loading="lazy" />
        <img src="/screenshots/IMG_2952.PNG" alt="soulMates screenshot" loading="lazy" />
        <img src="/screenshots/IMG_2953.PNG" alt="soulMates screenshot" loading="lazy" />
        <img src="/screenshots/IMG_2955.PNG" alt="soulMates screenshot" loading="lazy" />
        <img src="/screenshots/IMG_2956.PNG" alt="soulMates screenshot" loading="lazy" />
        <img src="/screenshots/IMG_2960.PNG" alt="soulMates screenshot" loading="lazy" />
        <img src="/screenshots/IMG_2961.PNG" alt="soulMates screenshot" loading="lazy" />
        <img src="/screenshots/IMG_2962.PNG" alt="soulMates screenshot" loading="lazy" />
        <img src="/screenshots/IMG_2963.PNG" alt="soulMates screenshot" loading="lazy" />
      </div>
      <button class="carousel-btn carousel-next" aria-label="Next" id="carouselNext">&rsaquo;</button>
    </div>
    <div class="carousel-dots" id="carouselDots"></div>
  </section>

  <script>
    const track = document.getElementById('carouselTrack')!;
    const prevBtn = document.getElementById('carouselPrev')!;
    const nextBtn = document.getElementById('carouselNext')!;
    const dotsContainer = document.getElementById('carouselDots')!;
    const images = track.querySelectorAll('img');
    let current = 0;

    // Create dots
    images.forEach((_, i) => {
      const dot = document.createElement('button');
      dot.className = 'carousel-dot' + (i === 0 ? ' active' : '');
      dot.setAttribute('aria-label', `Screenshot ${i + 1}`);
      dot.addEventListener('click', () => goTo(i));
      dotsContainer.appendChild(dot);
    });

    function goTo(index: number) {
      current = Math.max(0, Math.min(index, images.length - 1));
      const img = images[current] as HTMLElement;
      track.scrollTo({ left: img.offsetLeft - track.offsetLeft - (track.clientWidth - img.clientWidth) / 2, behavior: 'smooth' });
      updateDots();
    }

    function updateDots() {
      dotsContainer.querySelectorAll('.carousel-dot').forEach((dot, i) => {
        dot.classList.toggle('active', i === current);
      });
    }

    prevBtn.addEventListener('click', () => goTo(current - 1));
    nextBtn.addEventListener('click', () => goTo(current + 1));

    // Update current on scroll
    let scrollTimeout: ReturnType<typeof setTimeout>;
    track.addEventListener('scroll', () => {
      clearTimeout(scrollTimeout);
      scrollTimeout = setTimeout(() => {
        const center = track.scrollLeft + track.clientWidth / 2;
        let closest = 0;
        let minDist = Infinity;
        images.forEach((img, i) => {
          const el = img as HTMLElement;
          const mid = el.offsetLeft - track.offsetLeft + el.clientWidth / 2;
          const dist = Math.abs(center - mid);
          if (dist < minDist) { minDist = dist; closest = i; }
        });
        current = closest;
        updateDots();
      }, 50);
    });

    // Touch/swipe support is handled natively by scroll
  </script>
</BaseLayout>

<style>
  .hero {
    max-width: 720px;
    margin: 0 auto;
    padding: 80px 24px 64px;
    text-align: center;
    background: linear-gradient(135deg, #f4eee1 0%, #f8cba4 35%, #cdecf2 75%, #f4eee1 100%);
    border-radius: 0 0 40px 40px;
  }
  .hero-logo {
    width: 140px;
    height: auto;
    margin-bottom: 24px;
  }
  .hero h1 {
    font-size: 3rem;
    line-height: 1.15;
    font-weight: 800;
    letter-spacing: -0.02em;
  }
  .accent {
    color: var(--accent);
  }
  .subtitle {
    margin-top: 16px;
    font-size: 1.2rem;
    color: var(--muted);
    max-width: 480px;
    margin-left: auto;
    margin-right: auto;
  }
  .cta-row {
    margin-top: 32px;
    display: flex;
    gap: 12px;
    justify-content: center;
    flex-wrap: wrap;
  }
  .btn {
    display: inline-block;
    padding: 14px 32px;
    border-radius: var(--radius);
    font-weight: 600;
    font-size: 1rem;
    transition: opacity 0.2s;
  }
  .btn:hover {
    text-decoration: none;
    opacity: 0.85;
  }
  .btn-primary {
    background: var(--ink);
    color: #fff;
  }
  .btn-outline {
    border: 2px solid var(--accent);
    color: var(--accent);
  }

  .features {
    max-width: 960px;
    margin: 0 auto;
    padding: 0 24px 80px;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 32px;
  }
  .feature {
    background: rgba(255, 255, 255, 0.88);
    border-radius: 26px;
    padding: 28px 24px;
    border: 1px solid rgba(18, 20, 25, 0.07);
  }
  .feature-icon {
    font-size: 2rem;
    margin-bottom: 12px;
  }
  .feature h3 {
    font-size: 1.15rem;
    margin-bottom: 8px;
  }
  .feature p {
    color: var(--muted);
    font-size: 0.95rem;
  }

  .screenshots {
    max-width: 100%;
    margin: 0 auto;
    padding: 0 0 60px;
    text-align: center;
  }
  .screenshots h2 {
    font-size: 1.8rem;
    margin-bottom: 32px;
  }

  .carousel {
    position: relative;
    display: flex;
    align-items: center;
    max-width: 960px;
    margin: 0 auto;
  }
  .carousel-track {
    display: flex;
    gap: 16px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    padding: 8px 24px;
  }
  .carousel-track::-webkit-scrollbar {
    display: none;
  }
  .carousel-track img {
    flex: 0 0 auto;
    height: 480px;
    width: auto;
    border-radius: 20px;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
    scroll-snap-align: center;
    transition: transform 0.3s;
  }
  .carousel-track img:hover {
    transform: scale(1.02);
  }

  .carousel-btn {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 10;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    border: none;
    background: rgba(255, 255, 255, 0.9);
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.12);
    font-size: 1.5rem;
    color: var(--ink);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s;
  }
  .carousel-btn:hover {
    background: #fff;
  }
  .carousel-prev {
    left: 8px;
  }
  .carousel-next {
    right: 8px;
  }

  .carousel-dots {
    display: flex;
    justify-content: center;
    gap: 8px;
    margin-top: 20px;
  }
  .carousel-dots :global(.carousel-dot) {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    border: none;
    background: var(--ink);
    opacity: 0.2;
    cursor: pointer;
    padding: 0;
    transition: opacity 0.2s;
  }
  .carousel-dots :global(.carousel-dot.active) {
    opacity: 0.8;
  }

  @media (max-width: 640px) {
    .carousel-btn {
      display: none;
    }
    .carousel-track img {
      height: 400px;
    }
  }
</style>
